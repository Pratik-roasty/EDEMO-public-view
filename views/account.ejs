<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EDEMO | My Account</title>
    <link rel="stylesheet" href="/css/account.css">
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-logo">EDEMO</div>
        <nav>
            <div class="nav-item" onclick="window.location.href='/<%= username %>'">Dashboard</div>
        </nav>
        <div style="margin-top:auto; color: white; opacity: 0.8; font-weight: 600;">My Account</div>
        <button onclick="window.location.href='/<%= username %>/logout'" class="logout-btn">Logout</button>
    </aside>

    <main class="main-content">
        <div class="profile-card">
            <div class="avatar-circle">PY</div>
            <div class="profile-info">
                <h1><%=user.name%></h1>
                <p><strong>Username:</strong> <%=user.username%></p>
                <p><strong>Email:</strong> <%=user.email%></p>
            </div>
        </div>

        <div class="tab-container">
            <div class="tab active" onclick="switchTab(this, 'created')">Polls you created</div>
            <div class="tab" onclick="switchTab(this, 'voted')">Polls you voted in</div>
        </div>

        <div id="created" class="poll-grid">
            <% polls.forEach(function(poll) { %>
                <div class="poll-card">
                    <h3><%= poll.title %></h3>
                    <p><%= poll.description %></p>
                    <button onclick="window.location.href='/<%= username %>/<%= poll._id %>/viewPoll'" class="btn btn-primary">View Your Poll</button>
                </div>
            <% }); %>
        </div>

        <div id="voted" class="poll-grid" style="display: none;">
            <% userVotedPolls.forEach(function(poll) { %>
                <div class="poll-card">
                    <h3><%= poll.title %></h3>
                    <p><%= poll.description %></p>
                    <button onclick="window.location.href='/<%= username %>/<%= poll._id %>/viewPoll'" class="btn btn-primary">View Poll</button>
                </div>
            <% }); %>
        </div>
    </main>

    <script src="/js/account.js"></script>

</body>
</html>