<%- include("header") -%>
<h3><%=pollTitle%></h3>
<table  style="width: 30rem;">
    <tr>
        <th>Candidate Name</th>
        <th>Votes</th>
        <th>Vote</th>
    </tr>
    <%for(var i=0;i<candidates.length;i++){ %>
    <tr>
        <td><%=candidates[i]%></td>
        <td><%=votes[i]%></td>
        <td>
            <form action="/<%=username%>/<%=pollid%>/vote" method="post">
                <input type="hidden" name="candidate" value="<%=i%>">
                <button class="voteBtn" type="submit">Vote for <%=candidates[i]%></button>
            </form>
        </td>
    </tr>
    <%}%>

    <button class="btn btn-danger" style="display: none;" id="endBtn">End Poll</button>

    <h3 style="display: none;">Winner: <%=winner%></h3>
    <p style="display: none;">Reason to end poll: <%=endReason%></p>

    <div id="popupForm" class="form-popup">
    <form class="form-container" action="/<%=username%>/<%=pollid%>/endPoll" method="post">
        <h3>Confirm End Poll</h3>

        <input class="reason" type="text" placeholder="Reason for ending poll" name="reason" required><br>

        <button class="form-button btn btn-success" type="submit">Submit</button>
        <button class="form-button btn btn-danger" onclick="closeForm()">Close</button>
    </form>
    </div>

    <script>
        //Function to display message as alert if there is any message to be displayed.
        const message="<%=message%>";
        if(message){
            alert(message);
        }

        //end poll message alert
        const messageEndpoll="<%=messageEndpoll%>";
        if(messageEndpoll){
            if(messageEndpoll==="End"){
                alert("Poll ended successfully");
            } else{
                alert(messageEndpoll);
            }
        }

        //function to restrict the end poll button to be visible only to the publisher of the poll.
        const username="<%=username%>";
        const publisher="<%=publisher%>";
        if(username===publisher){
            document.querySelector("#endBtn").style.display="block";
        }


        function showForm() {
            document.getElementById("popupForm").style.display = "block";
        }
        function closeForm() {
            document.getElementById("popupForm").style.display = "none";
        }
        //when the end poll button is clicked, the popup form will be displayed to the user to enter the reason for ending the poll. 
        document.querySelector("#endBtn").addEventListener("click", showForm);
        
        //if poll is not active then hide the end poll button, disable the vote buttons, and display the reason for ending the poll and the winner of the poll.
        const isActive="<%=isActive%>";
        if(isActive==="false"){
            document.querySelector("#endBtn").style.display="none";
            const voteButtons=document.querySelectorAll(".voteBtn");
            voteButtons.forEach(function(button){
                button.disabled=true;
            });
            document.querySelector("h3").style.display="block";
            document.querySelector("p").style.display="block";
        }

    </script>
    <style>
        .form-popup {
            display: none;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            border: 2px solid #3590c4;
            z-index: 1000;
            background-color: white;
            padding-top: 5%;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            height: 30rem;
            width: 70rem;
            text-align: center;
        }

        .form-container input {
            display: block;
        }

        .reason {
            width: 40rem;
            height: 10rem;
            text-align: center;
            resize: none;
            margin-top: 2rem;
            margin-bottom: 2rem;
        }
        .form-button{
            width: 8rem;
            margin: 1rem;
        }


    </style>

</table>
<%-include("footer")-%>