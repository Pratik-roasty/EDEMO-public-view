<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EDEMO | Secure Digital Voting</title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-logo">EDEMO</div>
        <nav>
            <div class="nav-item active" onclick="showView('home')">Home</div>
            <div class="nav-item" onclick="showView('about')">About Website</div>
            <div class="nav-item" onclick="showView('create')">Create Poll</div>
            <div class="nav-item" onclick="showView('active-polls')">Active Polls</div>
            <div class="nav-item" onclick="showView('closed-polls')">Closed Polls</div>
        </nav>
        <div class="user-section">
            <div onclick="window.location.href='/<%= username %>/account'" style="font-weight:700"><%=name%></div>
            <button onclick="window.location.href='/<%= username %>/logout'" class="logout-btn">Logout Session</button>
        </div>
    </aside>

    <main class="main-content">
        
        <!-- HOME VIEW WITH DASHBOARD STATS -->
        <section id="home" class="view-section active">
            <h1>Welcome Back, <%= name %></h1>
            <p class="subtitle">Your real-time voting activity and poll status.</p>

            <div class="stats-grid">
                <div class="stat-card">
                    <h3><%= userTotalPolls %></h3>
                    <p>YOUR ACTIVE POLLS</p>
                </div>
                <div class="stat-card">
                    <h3><%= totalVotesReceived %></h3>
                    <p>TOTAL VOTES RECEIVED</p>
                </div>
                <div class="stat-card">
                    <h3><%= globalPolls %></h3>
                    <p>GLOBAL POLLS</p>
                </div>
            </div>

            <div class="card poll-card">
                <div>
                    <h2>Amplify your voice.</h2>
                    <p>Launch your next secure election with just a few clicks.</p>
                    <button class="btn btn-primary" onclick="showView('create')">+ New Election</button>
                </div>
                <img src="image_1ae697.png" style="width: 250px; border-radius: 12px;">
            </div>
        </section>

        <!-- ABOUT VIEW -->
        <section id="about" class="view-section">
            <h1>About Website</h1>
            <p class="subtitle">Empowering digital democracy with bank-grade security.</p>
            <div class="about-grid">
                <div class="about-item">Secure portal for important decisions and thorough data analysis.</div>
                <div class="about-item">Create and participate in public or private polls in a verified way.</div>
                <div class="about-item">Your data, selections, and privacy are maintained with total encryption.</div>
                <div class="about-item">Efficiently conduct elections without physical resource overhead.</div>
            </div>
        </section>

        <!-- CREATE POLL VIEW -->
        <section id="create" class="view-section">
            <h1>Create Poll</h1>
            <div class="card">
                <form action="/<%= username %>/create" method="POST">
                    <div class="form-group"><label>Poll Title</label><input type="text" name="pollTitle" required></div>
                    <div class="form-group"><label>Poll ID</label><input type="text" name="pollID" required></div>
                    <div class="form-group"><label>Description</label><textarea rows="3" name="desc" required></textarea></div>
                    <button class="btn btn-primary" type="submit">Add Candidates</button>
                </form>
            </div>
        </section>

        <!-- ACTIVE POLLS VIEW WITH SEARCH -->
        <section id="active-polls" class="view-section">
            <h1>Active Polls</h1>
            <p class="subtitle">Find and participate in ongoing elections.</p>
            
            <div class="search-container">
                <span class="search-icon">🔍</span>
                <input type="text" class="search-bar" placeholder="Search by title, ID, or category..." onkeyup="searchPolls(this.value)">
            </div>

            <div id="active-list">
                <% for(var i=0;i<activePolls.length;i++){ %>
                <div class="card poll-card poll-item">
                    <div><strong><%= activePolls[i].title %></strong><br><small>By: <%= activePolls[i].publisher %></small></div>
                    <form action="/<%=username%>/<%=activePolls[i]._id%>/viewPoll" method="get">
                        <button type="submit" class="btn btn-primary">View Poll</button>
                    </form>
                </div>
                <% } %>
            </div>
        </section>

        <!-- CLOSED POLLS VIEW -->
        <section id="closed-polls" class="view-section">
            <h1>Closed Polls</h1>
            <% for(var i=0;i<closedPolls.length;i++){ %>
            <div class="card poll-card">
                <div><strong><%= closedPolls[i].title %></strong><br><small>By: <%= closedPolls[i].publisher %></small></div>
                <form action="/<%=username%>/<%=closedPolls[i]._id%>/viewPoll" method="get">
                    <button type="submit" class="btn btn-outline">View Results</button>
                </form>
            </div>
            <% } %>
        </section>

    </main>

    <script src="/js/dashboard.js"></script>
</body>
</html>