<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EDEMO | Secure Digital Voting</title>
    <link rel="stylesheet" href="/css/index.css">
</head>
<body>

    <!-- Navigation -->
    <nav class="navbar">
        <div class="logo">EDEMO</div>
        <div class="nav-links">
            <button class="btn-secondary" onclick="toggleAuth('login')">Login</button>
            <button class="btn-primary" onclick="toggleAuth('register')">Get Started</button>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="hero">
        <div class="hero-content">
            <h1>Amplifying your voice.</h1>
            <p>The most trusted platform for organizations to host transparent, secure, and verifiable digital elections.</p>
            <div class="hero-btns">
                <button class="btn-primary" onclick="toggleAuth('register')">Create an Election</button>
                <button class="btn-outline" style="margin-left: 10px;">View Demo</button>
            </div>
        </div>
        <div class="hero-image">
            <!-- Referencing image_1ae697.png from original design -->
            <img src="image_1ae697.png" alt="Host Your Elections">
        </div>
    </header>

    <!-- Features Section -->
    <section class="features">
        <div class="feature-card">
            <h3>Verified Security</h3>
            <p>We use end-to-end encryption to ensure every vote is cast securely and anonymously. Your data never leaves our encrypted vault.</p>
        </div>
        <div class="feature-card">
            <h3>Auditable Results</h3>
            <p>Trust but verify. Our system generates a cryptographic receipt for every election, allowing for transparent post-poll audits.</p>
        </div>
        <div class="feature-card">
            <h3>User-Friendly</h3>
            <p>Whether on mobile or desktop, our interface is designed for maximum accessibility, ensuring every voice can be heard effortlessly.</p>
        </div>
    </section>

    <!-- Auth Modal -->
    <div id="authModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeModal()">&times;</span>
            
            <!-- Login State (based on image_1ae621.png) -->
            <div id="loginForm">
                <h2 style="margin-bottom: 0.5rem; color: var(--navy);">Welcome Back</h2>
                <p style="margin-bottom: 2rem; color: #64748b;">Please enter your credentials to continue.</p>
                <form action="/login" method="POST">
                    <input type="text" placeholder="Username" name="username" class="form-input">
                    <input type="password" placeholder="Password" name="password" class="form-input">
                    <button class="btn-primary btn-full">Login to Dashboard</button>
                </form>
                <p class="auth-toggle">Don't have an account? <span onclick="toggleAuth('register')">Register here</span></p>
            </div>

            <!-- Register State (based on image_1ae5fb.png) -->
            <div id="registerForm" style="display:none;">
                <h2 style="margin-bottom: 0.5rem; color: var(--navy);">Create Account</h2>
                <p style="margin-bottom: 2rem; color: #64748b;">Join EDEMO to start hosting your own secure polls.</p>
                <form action="/register" method="POST">
                    <input type="text" placeholder="Full Name" name="name" class="form-input">
                    <input type="email" placeholder="Email Address" name="email" class="form-input">
                    <input type="text" placeholder="Username" name="username" class="form-input">
                    <input type="password" placeholder="Password" name="password" class="form-input">
                    <button class="btn-primary btn-full">Create Account</button>
                </form>
                <p class="auth-toggle">Already a member? <span onclick="toggleAuth('login')">Login here</span></p>
            </div>
        </div>
    </div>

    <!-- --- JAVASCRIPT --- -->
     <script src="/js/index.js"></script>
</body>
</html>